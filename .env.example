# Backend API (capturas de emoción: foto + JSON)
VITE_BACKEND_URL=http://localhost:3006

# Pesos face-api.js (dashboard y juego). Carpeta bajo public/; sin barra final.
VITE_FACE_API_MODELS_URL=/models

# Registros del modal "Historial reciente" (GET /api/history/recent?limit=N)
VITE_EMOTION_HISTORY_RECENT_LIMIT=24

# Miniaturas del modal "Momentos divertidos" (GET /api/captures/processed?limit=N&offset=...)
VITE_FUN_MOMENTS_PAGE_SIZE=8

# --- Umbrales de captura automática ---

# Tiempo sosteniendo la misma emoción clara antes de enviar (ms)
VITE_EMOTION_CAPTURE_DELAY_MS=2500

# Confianza mínima (%) para capturar (feliz, triste, enojado, etc.)
VITE_EMOTION_CAPTURE_MIN_CONFIDENCE=48

# Neutral: umbral más alto
VITE_EMOTION_CAPTURE_NEUTRAL_MIN_CONFIDENCE=58

# Diferencia mínima (puntos %) entre 1.ª y 2.ª emoción
VITE_EMOTION_CAPTURE_MIN_DOMINANCE=15

# Probabilidad bruta face-api (0–1) de la emoción dominante
VITE_EMOTION_CAPTURE_MIN_SCORE=0.42

# Tolerancia de caída de confianza durante la espera
VITE_EMOTION_CAPTURE_CONFIDENCE_HYSTERESIS=8
